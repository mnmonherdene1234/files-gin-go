# Server port
SERVER_PORT=9999

# File storage directory
FILES_DIR=./files

# Static file path
STATIC_FILES_SERVE_PATH=/files

# Enable or disable static file serving
IS_SERVE_STATIC_FILES=true

# API key protection (disabled by default for security)
API_KEY_ENABLED=false
API_KEY_HEADER=X-API-Key
API_KEY=

# Memory used by ParseMultipartForm before spilling to temp files
MAX_UPLOAD_MEMORY_MB=32

# Maximum total upload size in MB
MAX_UPLOAD_SIZE_MB=100
